# Arteq Scraper — Environment Variables
# Copy to .env and fill in your keys

# Job Search APIs
JSEARCH_API_KEY=
JOBSPY_PROXY=

# AI Analysis
ANTHROPIC_API_KEY=

# Database
SUPABASE_URL=
SUPABASE_KEY=

# Decision Maker Search
APOLLO_API_KEY=

# Email (via Resend)
RESEND_API_KEY=
ALERT_EMAIL=niels@arteq.app

# Instantly.ai (email outreach)
INSTANTLY_API_KEY=
INSTANTLY_CAMPAIGN_ID=
INSTANTLY_AGENCY_CAMPAIGN_ID=

# Orchestrator — Outreach settings are in agent_config table (Supabase)
# outreach_mode: draft | auto | off
# outreach_daily_limit: 3
# outreach_from_email: niels@arteq.app (needs Resend domain verification)
# outreach_cc: niels@arteq.app
